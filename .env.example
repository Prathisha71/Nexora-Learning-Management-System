# Database – PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lms_db?schema=public"

# Backend configuration
PORT=3000
JWT_SECRET="your-jwt-secret-here"

# Frontend configuration
VITE_API_URL="http://localhost:3000/api"

# AI Tutor Integration
GEMINI_API_KEY="your-gemini-api-key-here"

# Gmail SMTP Configuration
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Nexora Learning <your-email@gmail.com>"

# MinIO Configuration (S3-compatible local object storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="lms-files"
MINIO_USE_SSL=false

# LiveKit Cloud Configuration
LIVEKIT_URL="your-livekit-url-here"
LIVEKIT_API_KEY="your-livekit-api-key-here"
LIVEKIT_API_SECRET="your-livekit-api-secret-here"
VITE_LIVEKIT_URL="your-livekit-url-here"

