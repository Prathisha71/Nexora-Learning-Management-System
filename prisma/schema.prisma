generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admins {
  id    String @id @db.Uuid
  dept  String @default("Operations")
  users users  @relation(fields: [id], references: [id], onDelete: Cascade)
}

model assignment_feedbacks {
  id                     String                 @id @db.Uuid
  submission_id          String                 @unique @db.Uuid
  teacher_id             String                 @db.Uuid
  marks_obtained         Float
  passed                 Boolean
  comment                String?
  graded_at              DateTime               @default(now())
  assignment_submissions assignment_submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade)
  teachers               teachers               @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

model assignment_submissions {
  id                   String                @id @db.Uuid
  assignment_id        String                @db.Uuid
  student_id           String                @db.Uuid
  submission_url       String
  status               SubmissionStatus      @default(SUBMITTED)
  submitted_at         DateTime              @default(now())
  assignment_feedbacks assignment_feedbacks?
  assignments          assignments           @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  students             students              @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, assignment_id])
}

model assignments {
  id                     String                   @id @db.Uuid
  title                  String
  description            String
  file_url               String?
  topic_id               String                   @db.Uuid
  max_marks              Float                    @default(100.0)
  passing_marks          Float                    @default(40.0)
  deadline               DateTime?
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  assignment_submissions assignment_submissions[]
  topics                 topics                   @relation(fields: [topic_id], references: [id], onDelete: Cascade)
}

model boards {
  id         String     @id @db.Uuid
  name       String     @unique
  code       String     @unique
  created_at DateTime   @default(now())
  updated_at DateTime
  classes    classes[]
  courses    courses[]
  students   students[]
}

model chapters {
  id                       String                     @id @db.Uuid
  name                     String
  sort_order               Int
  unit_id                  String                     @db.Uuid
  created_at               DateTime                   @default(now())
  updated_at               DateTime
  units                    units                      @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  student_chapter_progress student_chapter_progress[]
  topics                   topics[]

  @@unique([unit_id, name])
}

model classes {
  id         String     @id @db.Uuid
  name       String
  sort_order Int
  board_id   String     @db.Uuid
  created_at DateTime   @default(now())
  updated_at DateTime
  boards     boards     @relation(fields: [board_id], references: [id], onDelete: Cascade)
  courses    courses[]
  students   students[]
  subjects   subjects[]

  @@unique([board_id, name])
}

model course_notes {
  id                       String   @id @db.Uuid
  title                    String
  file_url                 String
  topic_id                 String   @db.Uuid
  sort_order               Int
  is_required_for_complete Boolean  @default(true)
  created_at               DateTime @default(now())
  updated_at               DateTime
  subject_title            String?
  uploaded_by_name         String?
  uploaded_by_user_id      String?
  topics                   topics   @relation(fields: [topic_id], references: [id], onDelete: Cascade)

  @@unique([topic_id, sort_order])
}

model course_resources {
  id         String   @id @db.Uuid
  title      String
  file_url   String
  file_type  String
  topic_id   String   @db.Uuid
  sort_order Int
  created_at DateTime @default(now())
  updated_at DateTime
  topics     topics   @relation(fields: [topic_id], references: [id], onDelete: Cascade)

  @@unique([topic_id, sort_order])
}

model course_videos {
  id                  String                @id @db.Uuid
  title               String
  video_url           String
  thumbnail_url       String?
  duration            Int
  drm_metadata        Json?
  topic_id            String                @db.Uuid
  sort_order          Int
  created_at          DateTime              @default(now())
  updated_at          DateTime
  drm_enabled         Boolean?              @default(false)
  encrypted_path      String?
  hls_path            String?
  dash_path           String?
  license_id          String?
  topics              topics                @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  video_watch_history video_watch_history[]

  @@unique([topic_id, sort_order])
}

model courses {
  id            String   @id @db.Uuid
  title         String
  description   String
  thumbnail_url String?
  subject_id    String   @db.Uuid
  class_id      String   @db.Uuid
  board_id      String   @db.Uuid
  teacher_id    String   @db.Uuid
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime
  boards        boards   @relation(fields: [board_id], references: [id], onDelete: Cascade)
  classes       classes  @relation(fields: [class_id], references: [id], onDelete: Cascade)
  subjects      subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  teachers      teachers @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

model learning_streaks {
  id                 String    @id @db.Uuid
  student_id         String    @unique @db.Uuid
  current_streak     Int       @default(0)
  longest_streak     Int       @default(0)
  last_activity_date DateTime?
  updated_at         DateTime
  students           students  @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model live_chat_messages {
  id            String       @id @db.Uuid
  live_class_id String       @db.Uuid
  user_id       String       @db.Uuid
  message       String
  sent_at       DateTime     @default(now())
  live_classes  live_classes @relation(fields: [live_class_id], references: [id], onDelete: Cascade)
  users         users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([live_class_id, sent_at])
}

model live_class_participants {
  id                     String           @id @db.Uuid
  live_class_id          String           @db.Uuid
  student_id             String           @db.Uuid
  joined_at              DateTime         @default(now())
  left_at                DateTime?
  total_duration_minutes Int?
  attendance_status      AttendanceStatus @default(PRESENT)
  live_classes           live_classes     @relation(fields: [live_class_id], references: [id], onDelete: Cascade)
  students               students         @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([live_class_id, student_id])
}

model live_classes {
  id                      String                    @id @db.Uuid
  title                   String
  description             String?
  subject_id              String                    @db.Uuid
  teacher_id              String                    @db.Uuid
  meeting_url             String
  scheduled_start         DateTime
  scheduled_end           DateTime
  status                  LiveClassStatus           @default(UPCOMING)
  recording_url           String?
  created_at              DateTime                  @default(now())
  updated_at              DateTime
  live_chat_messages      live_chat_messages[]
  live_class_participants live_class_participants[]
  subjects                subjects                  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  teachers                teachers                  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

model notifications {
  id                 String               @id @db.Uuid
  title              String
  body               String
  type               NotificationType     @default(SYSTEM)
  data               Json?
  created_at         DateTime             @default(now())
  user_notifications user_notifications[]
}

model payments {
  id              String         @id @db.Uuid
  subscription_id String         @db.Uuid
  amount          Decimal        @db.Decimal(10, 2)
  currency        String         @default("INR")
  status          PaymentStatus  @default(PENDING)
  gateway         PaymentGateway @default(RAZORPAY)
  transaction_id  String         @unique
  paid_at         DateTime?
  created_at      DateTime       @default(now())
  subscriptions   subscriptions  @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
}

model performance_reports {
  id              String   @id @db.Uuid
  student_id      String   @db.Uuid
  subject_id      String   @db.Uuid
  weak_topics     Json?
  strength_topics Json?
  recommendations Json?
  generated_at    DateTime @default(now())
  students        students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subjects        subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([student_id, subject_id])
}

model permissions {
  id               String             @id @db.Uuid
  name             String             @unique
  description      String?
  created_at       DateTime           @default(now())
  updated_at       DateTime
  role_permissions role_permissions[]
}

model quiz_attempts {
  id                      String                    @id @db.Uuid
  student_id              String                    @db.Uuid
  quiz_id                 String                    @db.Uuid
  attempt_number          Int
  score                   Float                     @default(0.0)
  passed                  Boolean                   @default(false)
  started_at              DateTime                  @default(now())
  completed_at            DateTime?
  duration_seconds        Int?
  quizzes                 quizzes                   @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  students                students                  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  quiz_question_responses quiz_question_responses[]
  quiz_results            quiz_results?

  @@unique([student_id, quiz_id, attempt_number])
}

model quiz_options {
  id                      String                    @id @db.Uuid
  question_id             String                    @db.Uuid
  option_text             String
  is_correct              Boolean                   @default(false)
  sort_order              Int
  quiz_questions          quiz_questions            @relation(fields: [question_id], references: [id], onDelete: Cascade)
  quiz_question_responses quiz_question_responses[]

  @@unique([question_id, sort_order])
}

model quiz_question_responses {
  id                 String         @id @db.Uuid
  attempt_id         String         @db.Uuid
  question_id        String         @db.Uuid
  selected_option_id String?        @db.Uuid
  text_response      String?
  is_correct         Boolean        @default(false)
  marks_awarded      Float          @default(0.0)
  quiz_attempts      quiz_attempts  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  quiz_questions     quiz_questions @relation(fields: [question_id], references: [id], onDelete: Cascade)
  quiz_options       quiz_options?  @relation(fields: [selected_option_id], references: [id])

  @@unique([attempt_id, question_id])
}

model quiz_questions {
  id                      String                    @id @db.Uuid
  quiz_id                 String                    @db.Uuid
  question_text           String
  question_type           QuestionType              @default(MCQ)
  marks                   Float                     @default(1.0)
  sort_order              Int
  created_at              DateTime                  @default(now())
  quiz_options            quiz_options[]
  quiz_question_responses quiz_question_responses[]
  quizzes                 quizzes                   @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@unique([quiz_id, sort_order])
}

model quiz_results {
  id            String        @id @db.Uuid
  attempt_id    String        @unique @db.Uuid
  student_id    String        @db.Uuid
  quiz_id       String        @db.Uuid
  score         Float
  percentage    Float
  passed        Boolean
  feedback      String?
  created_at    DateTime      @default(now())
  quiz_attempts quiz_attempts @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  quizzes       quizzes       @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  students      students      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id, quiz_id])
}

model quizzes {
  id                 String           @id @db.Uuid
  title              String
  description        String?
  topic_id           String           @db.Uuid
  passing_score      Float            @default(40.0)
  max_attempts       Int              @default(3)
  time_limit_minutes Int              @default(30)
  created_at         DateTime         @default(now())
  updated_at         DateTime
  quiz_attempts      quiz_attempts[]
  quiz_questions     quiz_questions[]
  quiz_results       quiz_results[]
  topics             topics           @relation(fields: [topic_id], references: [id], onDelete: Cascade)
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  created_at    DateTime    @default(now())
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

model roles {
  id               String             @id @db.Uuid
  name             String             @unique
  description      String?
  created_at       DateTime           @default(now())
  updated_at       DateTime
  role_permissions role_permissions[]
  user_roles       user_roles[]
}

model student_analytics {
  id                       String   @id @db.Uuid
  student_id               String   @unique @db.Uuid
  total_study_time_minutes Int      @default(0)
  average_quiz_score       Float    @default(0.0)
  overall_completion_rate  Float    @default(0.0)
  xp                       Int      @default(0)
  last_sync_at             DateTime @default(now())
  students                 students @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model student_chapter_progress {
  id                   String    @id @db.Uuid
  student_id           String    @db.Uuid
  chapter_id           String    @db.Uuid
  is_completed         Boolean   @default(false)
  completed_percentage Float     @default(0.0)
  unlocked             Boolean   @default(false)
  completed_at         DateTime?
  chapters             chapters  @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  students             students  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, chapter_id])
  @@index([student_id, is_completed])
}

model student_subject_progress {
  id                   String    @id @db.Uuid
  student_id           String    @db.Uuid
  subject_id           String    @db.Uuid
  is_completed         Boolean   @default(false)
  completed_percentage Float     @default(0.0)
  unlocked             Boolean   @default(false)
  completed_at         DateTime?
  students             students  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subjects             subjects  @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([student_id, subject_id])
  @@index([student_id, is_completed])
}

model student_topic_progress {
  id                   String    @id @db.Uuid
  student_id           String    @db.Uuid
  topic_id             String    @db.Uuid
  is_completed         Boolean   @default(false)
  watch_percent        Float     @default(0.0)
  quiz_completed       Boolean   @default(false)
  assignment_completed Boolean   @default(false)
  notes_viewed         Boolean   @default(false)
  unlocked             Boolean   @default(false)
  completed_at         DateTime?
  last_activity_at     DateTime  @default(now())
  students             students  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  topics               topics    @relation(fields: [topic_id], references: [id], onDelete: Cascade)

  @@unique([student_id, topic_id])
  @@index([student_id, is_completed])
}

model students {
  id                       String                     @id @db.Uuid
  class_id                 String                     @db.Uuid
  board_id                 String                     @db.Uuid
  enrolled_at              DateTime                   @default(now())
  updated_at               DateTime
  assignment_submissions   assignment_submissions[]
  learning_streaks         learning_streaks?
  live_class_participants  live_class_participants[]
  performance_reports      performance_reports[]
  quiz_attempts            quiz_attempts[]
  quiz_results             quiz_results[]
  student_analytics        student_analytics?
  student_chapter_progress student_chapter_progress[]
  student_subject_progress student_subject_progress[]
  student_topic_progress   student_topic_progress[]
  boards                   boards                     @relation(fields: [board_id], references: [id])
  classes                  classes                    @relation(fields: [class_id], references: [id])
  users                    users                      @relation(fields: [id], references: [id], onDelete: Cascade)
  subject_statistics       subject_statistics[]
  subscriptions            subscriptions[]
  video_watch_history      video_watch_history[]
}

model subject_statistics {
  id               String   @id @db.Uuid
  student_id       String   @db.Uuid
  subject_id       String   @db.Uuid
  topics_completed Int      @default(0)
  total_topics     Int      @default(0)
  quizzes_taken    Int      @default(0)
  quizzes_passed   Int      @default(0)
  average_score    Float    @default(0.0)
  updated_at       DateTime
  students         students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subjects         subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([student_id, subject_id])
}

model subjects {
  id                       String                     @id @db.Uuid
  name                     String
  code                     String
  sort_order               Int
  class_id                 String                     @db.Uuid
  created_at               DateTime                   @default(now())
  updated_at               DateTime
  courses                  courses[]
  live_classes             live_classes[]
  performance_reports      performance_reports[]
  student_subject_progress student_subject_progress[]
  subject_statistics       subject_statistics[]
  classes                  classes                    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  units                    units[]

  @@unique([class_id, code])
  @@unique([class_id, name])
}

model subscription_plans {
  id             String          @id @db.Uuid
  name           String          @unique
  description    String?
  price          Decimal         @db.Decimal(10, 2)
  duration_days  Int
  billing_period BillingPeriod   @default(MONTHLY)
  is_active      Boolean         @default(true)
  created_at     DateTime        @default(now())
  updated_at     DateTime
  subscriptions  subscriptions[]
}

model subscriptions {
  id                 String             @id @db.Uuid
  student_id         String             @db.Uuid
  plan_id            String             @db.Uuid
  status             SubscriptionStatus @default(PENDING)
  start_date         DateTime
  end_date           DateTime
  next_billing_date  DateTime?
  created_at         DateTime           @default(now())
  updated_at         DateTime
  payments           payments[]
  subscription_plans subscription_plans @relation(fields: [plan_id], references: [id])
  students           students           @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id, status])
}

model teachers {
  id                   String                 @id @db.Uuid
  bio                  String?
  qualification        String?
  created_at           DateTime               @default(now())
  updated_at           DateTime
  assignment_feedbacks assignment_feedbacks[]
  courses              courses[]
  live_classes         live_classes[]
  users                users                  @relation(fields: [id], references: [id], onDelete: Cascade)
}

model topics {
  id                     String                   @id @db.Uuid
  name                   String
  sort_order             Int
  chapter_id             String                   @db.Uuid
  prerequisite_topic_id  String?                  @db.Uuid
  require_watch_percent  Float                    @default(90.0)
  require_quiz_pass      Boolean                  @default(true)
  require_assign_submit  Boolean                  @default(false)
  require_notes_viewed   Boolean                  @default(false)
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  assignments            assignments[]
  course_notes           course_notes[]
  course_resources       course_resources[]
  course_videos          course_videos[]
  quizzes                quizzes[]
  student_topic_progress student_topic_progress[]
  chapters               chapters                 @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  topics                 topics?                  @relation("topicsTotopics", fields: [prerequisite_topic_id], references: [id])
  other_topics           topics[]                 @relation("topicsTotopics")

  @@unique([chapter_id, name])
}

model units {
  id         String     @id @db.Uuid
  name       String
  sort_order Int
  subject_id String     @db.Uuid
  created_at DateTime   @default(now())
  updated_at DateTime
  chapters   chapters[]
  subjects   subjects   @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([subject_id, name])
}

model user_notifications {
  id              String        @id @db.Uuid
  user_id         String        @db.Uuid
  notification_id String        @db.Uuid
  is_read         Boolean       @default(false)
  read_at         DateTime?
  notifications   notifications @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, notification_id])
  @@index([user_id, is_read])
}

model user_roles {
  user_id     String   @db.Uuid
  role_id     String   @db.Uuid
  assigned_at DateTime @default(now())
  roles       roles    @relation(fields: [role_id], references: [id], onDelete: Cascade)
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
}

model users {
  id                 String               @id @db.Uuid
  email              String               @unique
  password_hash      String
  first_name         String
  last_name          String
  phone_number       String?
  role               UserRole             @default(STUDENT)
  created_at         DateTime             @default(now())
  updated_at         DateTime
  location           String?
  admins             admins?
  live_chat_messages live_chat_messages[]
  students           students?
  teachers           teachers?
  user_notifications user_notifications[]
  user_roles         user_roles[]
}

model video_watch_history {
  id                String        @id @db.Uuid
  student_id        String        @db.Uuid
  video_id          String        @db.Uuid
  watch_duration    Int
  completed_percent Float
  resume_timestamp  Int           @default(0)
  playback_history  Json?
  last_watched_at   DateTime
  students          students      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  course_videos     course_videos @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([student_id, video_id])
  @@index([student_id, video_id])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum LiveClassStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  ACADEMIC
  SUBSCRIPTION
  SYSTEM
  LIVE_CLASS
}

enum PaymentGateway {
  RAZORPAY
  STRIPE
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
}

enum QuestionType {
  MCQ
  MSQ
  TF
  COMPREHENSION
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}
